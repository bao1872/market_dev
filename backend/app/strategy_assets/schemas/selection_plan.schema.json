{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Selection Plan V1.1",
  "type": "object",
  "required": [
    "name",
    "operator",
    "members"
  ],
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 80
    },
    "description": {
      "type": "string",
      "maxLength": 500
    },
    "operator": {
      "enum": [
        "ALL",
        "ANY"
      ]
    },
    "missing_member_policy": {
      "enum": [
        "FAIL_CLOSED",
        "IGNORE_MEMBER"
      ],
      "default": "FAIL_CLOSED"
    },
    "universe": {
      "type": "object"
    },
    "sort_spec": {
      "type": "array"
    },
    "notification": {
      "type": "object"
    },
    "members": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "strategy_key",
          "version_policy",
          "conditions"
        ],
        "properties": {
          "strategy_key": {
            "type": "string"
          },
          "version_policy": {
            "enum": [
              "PINNED",
              "STABLE_TRACK"
            ]
          },
          "strategy_version": {
            "type": [
              "string",
              "null"
            ]
          },
          "params": {
            "type": "object"
          },
          "conditions": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "metric_key",
                "operator",
                "value"
              ],
              "properties": {
                "metric_key": {
                  "type": "string"
                },
                "operator": {
                  "enum": [
                    "gt",
                    "gte",
                    "lt",
                    "lte",
                    "eq",
                    "between"
                  ]
                },
                "value": {},
                "value2": {}
              }
            }
          },
          "enabled": {
            "type": "boolean",
            "default": true
          },
          "position": {
            "type": "integer",
            "minimum": 0
          }
        }
      }
    }
  },
  "additionalProperties": false
}
