  "core_facts": [
    {
      "id": "T1_trend_direction",
      "dimension": "trend",
      "level": "core",
      "source_paths": ["structural_payload.primary.1d.dsa_segment.current_dsa_segment_dir"],
      "formula": "direct_value (1 -> UP, -1 -> DOWN, 0 -> NONE)",
      "raw_type": "categorical",
      "null_policy": "field_missing -> MISSING -> omit_row",
      "display_order": 1,
      "display_template": "DSA当前趋势方向为{上行/下行/中性}",
      "prohibited_interpretations": ["买卖方向", "未来涨跌预测"],
      "legacy_aliases": [],
      "default_ui_enabled": true
    },
    {
      "id": "T2_aligned_slope",
      "dimension": "trend",
      "level": "core",
      "source_paths": ["structural_payload.primary.1d.dsa_segment.current_dsa_segment_slope_atr_per_bar", "structural_payload.primary.1d.dsa_segment.current_dsa_segment_dir"],
      "formula": "dsa_dir * current_slope_atr_per_bar",
      "raw_type": "continuous",
      "unit": "ATR/bar",
      "null_policy": "dsa_dir_missing_or_zero -> MISSING; cur_slope_atr_missing -> MISSING -> omit_row",
      "display_order": 2,
      "display_template": "方向对齐斜率为{value:.4f} ATR/bar",
      "prohibited_interpretations": ["斜率大等于确定延续"],
      "legacy_aliases": [],
      "default_ui_enabled": true
    },
    {
      "id": "T4_trend_age",
      "dimension": "trend",
      "level": "core",
      "source_paths": ["structural_payload.primary.1d.dsa_segment.current_dsa_segment_age_bars"],
      "formula": "direct_value",
      "raw_type": "int",
      "null_policy": "field_missing -> MISSING -> omit_row",
      "display_order": 3,
      "display_template": "当前Segment已持续{value}根bar",
      "prohibited_interpretations": ["成熟", "衰竭", "即将反转"],
      "legacy_aliases": [],
      "default_ui_enabled": true
    },
    {
      "id": "T5_slope_ratio",
      "dimension": "trend",
      "level": "core",
      "source_paths": ["structural_payload.primary.1d.dsa_segment.current_dsa_segment_slope_atr_per_bar", "structural_payload.primary.1d.dsa_segment.prev_dsa_segment_slope_atr_per_bar"],
      "formula": "abs(current_slope_atr) / abs(previous_slope_atr); >upper_threshold -> 加速; <lower_threshold -> 减速; else -> 相近",
      "raw_type": "continuous->categorical",
      "null_policy": "prev_slope_atr_missing_or_zero -> MISSING -> omit_row",
      "display_order": 4,
      "display_template": "斜率相对前段：{加速/减速/相近}",
      "prohibited_interpretations": ["加速等于买入", "减速等于卖出"],
      "legacy_aliases": [],
      "default_ui_enabled": true,
      "thresholds_ref": "thresholds.t5_slope_ratio"
    },
    {
      "id": "M1_momentum_alignment",
      "dimension": "momentum",
      "level": "core",
      "source_paths": ["structural_payload.primary.1d.volatility_momentum.sqzmom_val", "structural_payload.primary.1d.dsa_segment.current_dsa_segment_dir"],
      "formula": "compare sign(sqzmom_val) with dsa_dir; same -> ALIGNED; opposite -> COUNTER; else -> ZERO",
      "raw_type": "categorical",
      "null_policy": "either_missing_or_dsa_dir_zero -> MISSING -> omit_row",
      "display_order": 5,
      "display_template": "SQZMOM动量与趋势{同向/逆向/中性}",
      "prohibited_interpretations": ["同向等于上涨信号"],
      "legacy_aliases": [],
      "default_ui_enabled": true
    },
    {
      "id": "M2_aligned_momentum",
      "dimension": "momentum",
      "level": "core",
      "source_paths": ["structural_payload.primary.1d.volatility_momentum.sqzmom_val", "structural_payload.primary.1d.dsa_segment.current_dsa_segment_dir"],
      "formula": "dsa_dir * sqzmom_val",
      "raw_type": "continuous",
      "null_policy": "either_missing_or_dsa_dir_zero -> MISSING -> omit_row",
