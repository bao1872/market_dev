# V1.1 交易平台后端 - 环境变量示例
# 复制为 .env 并按需修改
APP_ENV=development
LOG_LEVEL=INFO

# PostgreSQL（postgresql+psycopg://）
# 留空则按优先级自动解析：环境变量 → 本地 127.0.0.1:5432；无可用连接时服务启动失败。
# 生产环境必须通过环境变量配置 DATABASE_URL，禁止在代码或提交中写入真实密码。
# DATABASE_URL=postgresql+psycopg://bz:YOUR_PASSWORD@127.0.0.1:5432/bz_stock

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_SECRET=change-me
JWT_ALGORITHM=HS256
JWT_ACCESS_TTL_SECONDS=3600
JWT_REFRESH_TTL_SECONDS=604800

# 密钥管理（仅启动级占位，业务密钥进入加密配置中心）
SECRET_MASTER_KEY_PROVIDER=local-dev-only
SECRET_MASTER_KEY=replace-in-development-only
