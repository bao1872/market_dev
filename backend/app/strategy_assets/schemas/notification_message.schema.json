{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Notification Message V1.1",
  "type": "object",
  "required": [
    "message_type",
    "template_key",
    "template_version",
    "title",
    "summary",
    "resource_refs",
    "data_time"
  ],
  "properties": {
    "message_type": {
      "description": "消息类型枚举。MONITOR_MEMBER_EVENT 为仅历史兼容值，仅用于读取历史消息，新代码禁止生成（advice.md 第十一节遗留清理）。",
      "enum": [
        "MONITOR_EVENT",
        "MONITOR_MEMBER_EVENT",
        "SYSTEM_ALERT",
        "CHANNEL_ALERT"
      ]
    },
    "template_key": {
      "type": "string"
    },
    "template_version": {
      "type": "string"
    },
    "locale": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "summary": {
      "type": "string"
    },
    "facts": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "timeline": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "items": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "actions": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "resource_refs": {
      "type": "object"
    },
    "data_time": {
      "type": "string",
      "format": "date-time"
    },
    "disclaimer": {
      "type": "string"
    }
  },
  "additionalProperties": false
}
